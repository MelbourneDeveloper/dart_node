root = true

# ============================================================
# Universal settings
# ============================================================
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 80

# ============================================================
# Web / config formats — 2-space indent
# ============================================================
[*.{json,jsonc}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{css,scss,less,html,htm}]
indent_size = 2

[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false

# ============================================================
# Dart — 2-space indent, 80 char line length
# ============================================================
[*.dart]
indent_size = 2
max_line_length = 80

# ============================================================
# JavaScript / TypeScript (interop files)
# ============================================================
[*.{js,ts,mjs,cjs}]
indent_size = 2

# ============================================================
# Build files
# ============================================================
[Makefile]
indent_style = tab
indent_size = 4

[*.sh]
indent_size = 2
